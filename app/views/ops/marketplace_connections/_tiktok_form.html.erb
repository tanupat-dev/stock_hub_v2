<article class="marketplace-card">
  <div class="marketplace-card__header">
    <div>
      <h2 class="marketplace-card__title">Connect TikTok Shop</h2>
      <p class="marketplace-card__subtitle">
        Use the app credentials and shop ID for this specific in-house TikTok shop.
      </p>
    </div>
  </div>

  <form
    class="connection-form"
    data-action="submit->marketplace-connections#submitTiktok"
  >
    <div
      class="form-alert is-hidden"
      data-marketplace-connections-target="tiktokError"
    ></div>

    <div class="form-grid">
      <div class="form-field">
        <label class="form-label" for="tiktok_shop_name">Shop Name</label>
        <input
          id="tiktok_shop_name"
          name="shop_name"
          type="text"
          class="form-input"
          placeholder="e.g. TikTok Main Shop"
          data-marketplace-connections-target="tiktokShopName"
        >
      </div>

      <div class="form-field">
        <label class="form-label" for="tiktok_shop_id">TikTok Shop ID</label>
        <input
          id="tiktok_shop_id"
          name="shop_id"
          type="text"
          class="form-input"
          placeholder="Enter TikTok shop ID"
          data-marketplace-connections-target="tiktokShopId"
          required
        >
        <div class="form-help">Use the shop ID tied to this TikTok app.</div>
      </div>

      <div class="form-field">
        <label class="form-label" for="tiktok_app_key">App Key</label>
        <input
          id="tiktok_app_key"
          name="app_key"
          type="text"
          class="form-input"
          placeholder="Enter TikTok app key"
          data-marketplace-connections-target="tiktokAppKey"
          required
        >
      </div>

      <div class="form-field">
        <label class="form-label" for="tiktok_app_secret">App Secret</label>
        <input
          id="tiktok_app_secret"
          name="app_secret"
          type="password"
          class="form-input"
          placeholder="Enter TikTok app secret"
          data-marketplace-connections-target="tiktokAppSecret"
          required
        >
      </div>
    </div>

    <div class="form-actions">
      <button
        type="submit"
        class="ui-button ui-button--primary"
        data-marketplace-connections-target="tiktokSubmitButton"
      >
        Connect TikTok
      </button>
    </div>
  </form>
</article>