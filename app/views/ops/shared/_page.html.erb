<div class="page">
  <header class="page-header">
    <div>
      <h1><%= title %></h1>
      <% if local_assigns[:subtitle].present? %>
        <p><%= subtitle %></p>
      <% end %>
    </div>

    <% if local_assigns[:actions].present? %>
      <div class="page-header__actions">
        <%= actions %>
      </div>
    <% end %>
  </header>

  <div class="page-body">
    <%= yield %>
  </div>
</div>